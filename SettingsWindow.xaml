<Window x:Class="ETSOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="580"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <Style x:Key="ModernScrollThumb" TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2" MinHeight="20"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="{TemplateBinding Background}" CornerRadius="2" MinHeight="20"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="{TemplateBinding Background}" CornerRadius="2" MinHeight="20"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmptyRepeatButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="4"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource EmptyRepeatButton}" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource EmptyRepeatButton}" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" Grid.Column="0" CanContentScroll="{TemplateBinding CanContentScroll}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Opacity="1"
                                       Width="4"
                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Style="{StaticResource ModernScrollBar}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3F9843"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="templateRoot" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="25" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1" Background="Transparent">
                        <Path x:Name="arrow" Data="M0,0 L4.5,4.5 L9,0" Stroke="{DynamicResource MainTextBrush}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="templateRoot" Property="Background" Value="{DynamicResource CardBackgroundHoverBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleButton" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Template="{StaticResource ComboBoxToggleButton}" />
                            <ContentPresenter x:Name="contentPresenter" IsHitTestVisible="False" Margin="12,0,30,0" VerticalAlignment="Center" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                            <Popup x:Name="popup" AllowsTransparency="True" Placement="Bottom" PopupAnimation="None">
                                <Border x:Name="dropDownBorder" MinWidth="{Binding ActualWidth, ElementName=toggleButton}" MaxHeight="200" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Margin="0,4,0,0" RenderTransformOrigin="0.5,0" Opacity="0">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleY="0.8"/>
                                    </Border.RenderTransform>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <BooleanAnimationUsingKeyFrames Storyboard.TargetName="popup" Storyboard.TargetProperty="IsOpen">
                                                <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True"/>
                                            </BooleanAnimationUsingKeyFrames>
                                            <DoubleAnimation Storyboard.TargetName="dropDownBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.20">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="dropDownBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.20">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="dropDownBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="dropDownBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.8" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <BooleanAnimationUsingKeyFrames Storyboard.TargetName="popup" Storyboard.TargetProperty="IsOpen">
                                                <DiscreteBooleanKeyFrame KeyTime="0:0:0.15" Value="False"/>
                                            </BooleanAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSwitchToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Background}" BorderBrush="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=BorderBrush}" BorderThickness="1" CornerRadius="13" />
                            <Ellipse x:Name="Thumb" Width="20" Height="20" Fill="White" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.30" ShadowDepth="1" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#43A047" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="#43A047" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="22" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.97" />
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.98" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="12" Padding="20" Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" Opacity="{DynamicResource ShadowOpacity}" Direction="270" ShadowDepth="5"/>
        </Border.Effect>
        <Grid>
            <StackPanel>
                <!-- Header -->
            <Grid Margin="0,0,0,18">
                <TextBlock x:Name="SettingsTitle" Text="SETTINGS" Foreground="{DynamicResource MainTextBrush}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Click="BtnCloseSettings_Click" HorizontalAlignment="Right" Width="32" Height="32" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6">
                                <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="{DynamicResource MutedTextBrush}" StrokeThickness="2" Stretch="Uniform" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Tabs Selection -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="TabGeneralBtn" Grid.Column="0" Content="General" Height="30" IsChecked="True" Checked="TabGeneralBtn_Checked" Style="{StaticResource TabButtonStyle}" />
                <RadioButton x:Name="TabAppearanceBtn" Grid.Column="2" Content="Appearance" Height="30" Checked="TabAppearanceBtn_Checked" Style="{StaticResource TabButtonStyle}" />
                <RadioButton x:Name="TabCloudBtn" Grid.Column="4" Content="Cloud" Height="30" Checked="TabCloudBtn_Checked" Style="{StaticResource TabButtonStyle}" />
                <RadioButton x:Name="TabLogbookBtn" Grid.Column="6" Content="Logbook" Height="30" Checked="TabLogbookBtn_Checked" Style="{StaticResource TabButtonStyle}" />
            </Grid>

            <!-- Tab: General Content -->
            <Grid x:Name="TabGeneralContent" Margin="0,0,0,16" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0">
                    <!-- UI Mode -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock x:Name="UIModeLabel" Text="UI Mode" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="UIModeSelector" Grid.Column="0" SelectionChanged="UIModeSelector_SelectionChanged">
                            </ComboBox>
                            <Button x:Name="CustomModeConfigBtn" Grid.Column="1" Content="Change" Foreground="White" FontSize="11" Margin="6,0,0,0" Padding="8,2" VerticalAlignment="Center" Visibility="Collapsed" Click="CustomModeConfigBtn_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{DynamicResource HeaderButtonBackgroundBrush}" CornerRadius="6" BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Auto-hide toggle -->
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="AutoHideLabel" Text="Auto-hide" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="AutoHideToggle" Style="{StaticResource ModernSwitchToggleStyle}" Checked="AutoHideToggle_Checked" Unchecked="AutoHideToggle_Unchecked" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="AutoHideHint" Text="Uses TruckBook status only. Temporarily hides the selected UI mode when status is calm." Foreground="#8A8F98" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Opacity -->
                    <Grid VerticalAlignment="Center" Margin="0,4,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="OpacityLabel" Grid.Column="0" Text="Opacity" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <Slider x:Name="OpacitySlider" Grid.Column="1" Minimum="40" Maximum="100" Value="85" VerticalAlignment="Center" ValueChanged="OpacitySlider_ValueChanged"/>
                        <TextBlock x:Name="OpacityValue" Grid.Column="2" Text="85%" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center" Width="35" TextAlignment="Right"/>
                    </Grid>

                    <!-- Scale -->
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ScaleLabel" Grid.Column="0" Text="Scale" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ScaleSelector" Grid.Column="1" SelectionChanged="ScaleSelector_SelectionChanged">
                            <ComboBoxItem Content="75%" Tag="75"/>
                            <ComboBoxItem Content="100%" Tag="100" IsSelected="True"/>
                            <ComboBoxItem Content="125%" Tag="125"/>
                            <ComboBoxItem Content="150%" Tag="150"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2">
                    <!-- Language -->
                    <Grid VerticalAlignment="Center" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LanguageLabel" Grid.Column="0" Text="Language" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <ComboBox x:Name="LanguageSelector" Grid.Column="1" SelectionChanged="LanguageSelector_SelectionChanged">
                            <ComboBoxItem Content="English" Tag="en"/>
                            <ComboBoxItem Content="Українська" Tag="uk"/>
                        </ComboBox>
                    </Grid>

                    <!-- Speed Warning -->
                    <Grid VerticalAlignment="Center" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SpeedWarningLabel" Grid.Column="0" Text="Speed warning" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBox x:Name="SpeedWarningBox" Grid.Column="1" Height="28" VerticalContentAlignment="Center" TextAlignment="Center" Background="{DynamicResource InputBackgroundBrush}" Foreground="White" BorderBrush="{DynamicResource InputBorderBrush}" TextChanged="SpeedWarningBox_TextChanged"/>
                        <Grid Grid.Column="2" Margin="6,0,0,0" Width="26" Height="28" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="14"/>
                            </Grid.RowDefinitions>
                            <Button x:Name="SpeedWarningUp" Grid.Row="0" Height="14" Click="SpeedWarningUp_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0">
                                            <TextBlock Text="▲" Foreground="#B0B0B0" FontSize="7" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource InputHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="SpeedWarningDown" Grid.Row="1" Height="14" Click="SpeedWarningDown_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{DynamicResource InputBackgroundBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4">
                                            <TextBlock Text="▼" Foreground="#B0B0B0" FontSize="7" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-1,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource InputHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Tab: Appearance Content -->
            <Grid x:Name="TabAppearanceContent" Margin="0,0,0,16" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <!-- Theme -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock x:Name="ThemeLabel" Text="Theme" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ThemeSelector" SelectionChanged="AppearanceSetting_SelectionChanged" />
                    </StackPanel>
                    
                    <!-- Card Style -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock x:Name="CardStyleLabel" Text="Card Style" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CardStyleSelector" SelectionChanged="AppearanceSetting_SelectionChanged" />
                    </StackPanel>
                    
                    <!-- Global Accent Color -->
                    <StackPanel x:Name="GlobalAccentPanel" Margin="0,0,0,16">
                        <TextBlock x:Name="GlobalAccentLabel" Text="Global Accent" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="GlobalAccentSelector" SelectionChanged="AppearanceSetting_SelectionChanged" />
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="2">
                    <!-- Accent Coloring Mode -->
                    <StackPanel Margin="0,0,0,4">
                        <TextBlock x:Name="AccentModeLabel" Text="Accent Mode" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="AccentModeSelector" SelectionChanged="AccentMode_SelectionChanged" />
                    </StackPanel>
                    <TextBlock x:Name="AccentModeHint" Text="Uniform applies your accent everywhere. Custom allows picking per tile." Foreground="#8A8F98" FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap"/>
                    
                    <StackPanel x:Name="CustomAccentsPanel" Visibility="Collapsed">
                        <TextBlock x:Name="CustomAccentsTitle" Text="Tile Colors" Foreground="{DynamicResource MainTextBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Button x:Name="BtnCustomizeTileColors" Content="Customize Tile Colors" Click="BtnCustomizeTileColors_Click" Height="28" Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource MainTextBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource InputHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Tab: Cloud Content -->
            <Grid x:Name="TabCloudContent" Margin="0,0,0,16" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="CloudSyncTitle" Text="Cloud Sync" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock x:Name="CloudStatusLabel" Text="Status:" Foreground="#8A8F98" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CloudStatusValue" Text="Not available" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="CloudEnableLabel" Text="Enable Cloud Sync" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="CloudSyncToggle" Style="{StaticResource ModernSwitchToggleStyle}" Checked="CloudSyncToggle_Checked" Unchecked="CloudSyncToggle_Unchecked" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="CloudSyncHint" Text="When enabled, widget settings are saved to your TruckSim Cloud profile." Foreground="#8A8F98" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button x:Name="BtnCloudSyncNow" Grid.Row="0" Grid.Column="0" Content="Sync now" Height="30" Background="{DynamicResource CardBackgroundBrush}" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnCloudSyncNow_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#4CAE50"/></Trigger>
                                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnCloudDownload" Grid.Row="0" Grid.Column="2" Content="Download from cloud" Height="30" Background="{DynamicResource CardBackgroundBrush}" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnCloudDownload_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#1976D2"/></Trigger>
                                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnCloudUpload" Grid.Row="2" Grid.Column="0" Content="Upload this PC" Height="30" Background="{DynamicResource CardBackgroundBrush}" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnCloudUpload_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#1976D2"/></Trigger>
                                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnCloudDelete" Grid.Row="2" Grid.Column="2" Content="Delete cloud backup" Height="30" Background="{DynamicResource CardBackgroundBrush}" Foreground="#E57373" BorderThickness="0" Cursor="Hand" Click="BtnCloudDelete_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#D32F2F"/><Setter Property="Foreground" Value="White"/></Trigger>
                                        <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Tab: Logbook Content -->
            <Grid x:Name="TabLogbookContent" Margin="0,0,0,16" Visibility="Collapsed">
                <!-- Logbook List View -->
                <Grid x:Name="LogbookListView" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" x:Name="LogbookTitleLabel" Text="Recent Trips (0)" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                    
                    <!-- Scrolling List -->
                    <ScrollViewer Grid.Row="2" Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="320" Margin="0,0,-10,0">
                        <StackPanel x:Name="LogbookTripsList" Margin="0,0,10,0">
                            <!-- Cards added programmatically -->
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock x:Name="LogbookEmptyText" Grid.Row="2" Text="No trips recorded yet." Foreground="#8A8F98" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    <TextBlock x:Name="LogbookFreeLimitText" Grid.Row="4" Text="Showing last 5 trips. Supporter unlocks full history." Foreground="#EABF20" FontSize="12" HorizontalAlignment="Center" Visibility="Collapsed"/>
                </Grid>

                <!-- Logbook Detail View -->
                <Grid x:Name="LogbookDetailView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Detail Header with Back Button -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="BtnLogbookBack" Grid.Column="0" Width="30" Height="30" Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource MainTextBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" FontSize="16" FontWeight="Bold" Cursor="Hand" Click="BtnLogbookBack_Click">
                            <Button.Content>
                                <TextBlock Text="←" Margin="0,-2,0,0"/>
                            </Button.Content>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="{DynamicResource InputHoverBrush}"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock Grid.Column="2" x:Name="LogbookDetailTitle" Text="Trip Details" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <!-- Details Scroll -->
                    <ScrollViewer Grid.Row="2" Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="320" Margin="0,0,-10,0">
                        <StackPanel x:Name="LogbookDetailPanel" Margin="0,0,10,0">
                            <!-- Detail rows added programmatically -->
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Export Buttons -->
                    <Grid Grid.Row="4" x:Name="LogbookExportGrid" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="BtnExportCsv" Grid.Column="0" Content="Export CSV" Height="30" Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource MainTextBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Cursor="Hand" Click="BtnExportCsv_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="{DynamicResource InputHoverBrush}"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <Button x:Name="BtnExportJson" Grid.Column="2" Content="Export JSON" Height="30" Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource MainTextBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Cursor="Hand" Click="BtnExportJson_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="{DynamicResource InputHoverBrush}"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Bottom Section -->
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Supporter Banner -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="LicenseSectionTitle" Text="⭐ Стати Supporter" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="LicenseStatusText" Text="Free" Foreground="#A0A0A0" FontSize="13"/>
                        </StackPanel>

                        <Button x:Name="BtnManageLicense" Grid.Column="1" Content="Стати Supporter" Width="130" Height="32" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnManageLicense_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnCheckUpdate" Grid.Column="0" Content="🔄 Перевірити оновлення" Height="36" Background="#3F9843" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="BtnCheckUpdate_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#4CAE50"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnDonate" Grid.Column="2" Content="💛 Підтримати" Height="36" Background="#EABF20" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnDonate_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#F5CB32"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Version -->
            <TextBlock x:Name="VersionLabel" Text="v1.0.0" Foreground="#555555" FontSize="11" HorizontalAlignment="Center" Margin="0,16,0,0"/>
            <TextBlock x:Name="UpdateStatusText" Text="" Foreground="#B0B0B0" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>

            </StackPanel>
            
            <!-- Toast Notification -->
            <Border x:Name="ToastOverlay" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,32"
                    Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,10"
                    Opacity="0" IsHitTestVisible="False" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.5" ShadowDepth="4"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastTranslate" Y="10"/>
                </Border.RenderTransform>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⭐" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#F5C542"/>
                    <TextBlock x:Name="ToastText" Text="Requires Supporter subscription" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
