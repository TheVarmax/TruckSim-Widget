<Window x:Class="ETSOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="390"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2A2D35" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40444F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="templateRoot" Background="#2A2D35" BorderBrush="#3A3D45" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="25" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1" Background="Transparent">
                        <Path x:Name="arrow" Data="M0,0 L4.5,4.5 L9,0" Stroke="White" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="templateRoot" Property="Background" Value="#353840" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2A2D35" />
            <Setter Property="BorderBrush" Value="#3A3D45" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleButton" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Template="{StaticResource ComboBoxToggleButton}" />
                            <ContentPresenter x:Name="contentPresenter" IsHitTestVisible="False" Margin="12,0,30,0" VerticalAlignment="Center" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                            <Popup x:Name="popup" AllowsTransparency="True" Placement="Bottom" PopupAnimation="None">
                                <Border x:Name="dropDownBorder" MinWidth="{Binding ActualWidth, ElementName=toggleButton}" MaxHeight="150" Background="#2A2D35" BorderBrush="#3A3D45" BorderThickness="1" CornerRadius="6" Margin="0,4,0,0" RenderTransformOrigin="0.5,0" Opacity="0">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleY="0.8"/>
                                    </Border.RenderTransform>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <BooleanAnimationUsingKeyFrames Storyboard.TargetName="popup" Storyboard.TargetProperty="IsOpen">
                                                <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True"/>
                                            </BooleanAnimationUsingKeyFrames>
                                            <DoubleAnimation Storyboard.TargetName="dropDownBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.20">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="dropDownBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.20">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="dropDownBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="dropDownBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.8" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <BooleanAnimationUsingKeyFrames Storyboard.TargetName="popup" Storyboard.TargetProperty="IsOpen">
                                                <DiscreteBooleanKeyFrame KeyTime="0:0:0.15" Value="False"/>
                                            </BooleanAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1A1C20" CornerRadius="12" Padding="20" Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="25" Opacity="0.6" Direction="270" ShadowDepth="5"/>
        </Border.Effect>

        <StackPanel>
            <!-- Header -->
            <Grid Margin="0,0,0,18">
                <TextBlock x:Name="SettingsTitle" Text="SETTINGS" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Click="BtnCloseSettings_Click" HorizontalAlignment="Right" Width="32" Height="32" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="#2A2D35" CornerRadius="6">
                                <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="#B0B0B0" StrokeThickness="2" Stretch="Uniform" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- UI Mode -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                <TextBlock x:Name="UIModeLabel" Text="UI Mode" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="UIModeSelector" Width="152" SelectionChanged="UIModeSelector_SelectionChanged">
                    <ComboBoxItem Content="Full Interface" Tag="full"/>
                    <ComboBoxItem Content="Minimalism" Tag="minimal"/>
                </ComboBox>
            </StackPanel>

            <!-- Opacity -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,20,0,0">
                <TextBlock x:Name="OpacityLabel" Text="Opacity" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <Slider x:Name="OpacitySlider" Minimum="40" Maximum="100" Value="85" Width="150" VerticalAlignment="Center" ValueChanged="OpacitySlider_ValueChanged"/>
                <TextBlock x:Name="OpacityValue" Text="85%" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Scale -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,16,0,0">
                <TextBlock x:Name="ScaleLabel" Text="Scale" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="ScaleSelector" Width="150" SelectionChanged="ScaleSelector_SelectionChanged">
                    <ComboBoxItem Content="75%" Tag="75"/>
                    <ComboBoxItem Content="100%" Tag="100" IsSelected="True"/>
                    <ComboBoxItem Content="125%" Tag="125"/>
                    <ComboBoxItem Content="150%" Tag="150"/>
                </ComboBox>
            </StackPanel>

            <!-- Language -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,16,0,0">
                <TextBlock x:Name="LanguageLabel" Text="Language" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="LanguageSelector" Width="150" SelectionChanged="LanguageSelector_SelectionChanged">
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="Українська" Tag="uk"/>
                </ComboBox>
            </StackPanel>

            <!-- Speed Warning -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,16,0,0">
                <TextBlock x:Name="SpeedWarningLabel" Text="Speed warning" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBox x:Name="SpeedWarningBox" Width="100" Height="28" VerticalContentAlignment="Center" TextAlignment="Center" Background="#2A2D35" Foreground="White" BorderBrush="#3A3D45" TextChanged="SpeedWarningBox_TextChanged"/>
                <Grid Margin="6,0,0,0" Width="26" Height="28" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="14"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="SpeedWarningUp" Grid.Row="0" Height="14" Click="SpeedWarningUp_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="#2A2D35" BorderBrush="#3A3D45" BorderThickness="1,1,1,0" CornerRadius="4,4,0,0">
                                    <TextBlock Text="▲" Foreground="#B0B0B0" FontSize="7" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#353840"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="SpeedWarningDown" Grid.Row="1" Height="14" Click="SpeedWarningDown_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="#2A2D35" BorderBrush="#3A3D45" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4">
                                    <TextBlock Text="▼" Foreground="#B0B0B0" FontSize="7" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-1,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#353840"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Update Buttons -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnCheckUpdate" Grid.Column="0" Content="🔄 Check for updates" Click="BtnCheckUpdate_Click"
                        Background="#43A047" Foreground="White" BorderThickness="0"
                        Height="32" HorizontalAlignment="Stretch" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="#2A2C31"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnDonate" Grid.Column="2" Content="💛 Donate" Click="BtnDonate_Click"
                        Background="#E8BA23" Foreground="Black" BorderThickness="0"
                        Height="32" HorizontalAlignment="Stretch" Cursor="Hand" FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <TextBlock x:Name="UpdateStatusText" Text="" Foreground="#888888"
                       FontSize="12" HorizontalAlignment="Center"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>



            <!-- Version -->
            <TextBlock x:Name="VersionLabel" Text="" Foreground="#555555" FontSize="10" HorizontalAlignment="Center" Margin="0,15,0,0"/>
        </StackPanel>
    </Border>
</Window>
