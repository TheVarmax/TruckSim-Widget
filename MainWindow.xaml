<Window x:Class="ETSOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TruckSim Widget"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style x:Key="WindowBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtnStyle" TargetType="Button" BasedOn="{StaticResource WindowBtnStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkbox style for dark theme -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="#1A1C20" CornerRadius="0" Padding="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.6" Direction="270" ShadowDepth="5"/>
        </Border.Effect>

        <!-- Wrapper for overlapping settings panel -->
        <Grid>
            <!-- MAIN UI -->
            <Grid x:Name="MainUI">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ROW 0: Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="TbStatus" Text="TB • ONLINE" Foreground="#4CAF50" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Settings Button -->
                        <Button Click="BtnSettings_Click" Style="{StaticResource WindowBtnStyle}" ToolTip="Settings" Margin="0,0,5,0">
                            <Path Data="M19.4 13c0-.33.05-.66.05-1s-.02-.67-.05-1l2.1-1.66c.2-.15.25-.42.13-.64l-2-3.46c-.12-.22-.4-.3-.6-.22l-2.5 1c-.5-.4-1.07-.73-1.68-.98l-.4-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.5.42l-.37 2.65c-.6.25-1.17.58-1.68.98l-2.5-1c-.22-.08-.48 0-.6.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.03.33-.07.67-.07 1s.04.67.07 1l-2.1 1.66c-.2.15-.25.42-.12.64l2 3.46c.12.22.38.3.6.22l2.5-1c.5.4 1.07.73 1.68.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.5-.42l.37-2.65c.6-.25 1.17-.58 1.68-.98l2.5 1c.22.08.48 0 .6-.22l2-3.46c.12-.22.07-.49-.12-.64L19.4 13zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" Fill="White" Stretch="Uniform" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="BtnTopmost" Click="BtnTopmost_Click" Style="{StaticResource WindowBtnStyle}" ToolTip="Pin" Margin="0,0,5,0">
                            <Path x:Name="PinIcon" Data="M16,12V4H17V2H7V4H8V12L6,14V16H11V22H13V16H18V14L16,12Z" Fill="White" Stretch="Uniform" Width="12" Height="12"/>
                        </Button>
                        <Button Click="BtnMinimize_Click" Style="{StaticResource WindowBtnStyle}">
                            <Path Data="M0,0 L12,0" Stroke="White" StrokeThickness="2" Stretch="Uniform" Width="10" VerticalAlignment="Center"/>
                        </Button>
                        <Button Click="BtnClose_Click" Style="{StaticResource CloseBtnStyle}" Margin="5,0,0,0">
                            <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="White" StrokeThickness="2" Stretch="Uniform" Width="10" Height="10" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ROW 1: Status & Distance -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock x:Name="GameStatus" Text="GAME: ACTIVE" Foreground="#7AC5CD" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DistanceInfo" Text="0 / 0 km (0 left)" Foreground="#52C14F" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- ROW 2: Work Status -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock x:Name="StatusLabel" Text="Status: " Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusValue" Text="Waiting..." Foreground="#A0A0A0" FontSize="16" FontWeight="SemiBold"/>
                    <Border x:Name="StatusCheckIconContainer" Visibility="Collapsed" BorderBrush="#52C14F" BorderThickness="2" CornerRadius="0" Width="20" Height="20" Background="Transparent" VerticalAlignment="Center" Margin="8,0,0,0">
                        <Path Data="M 4,10 L 8,14 L 15,5" Stroke="#52C14F" StrokeThickness="2" Stretch="Uniform" Margin="2"/>
                    </Border>
                </StackPanel>

                <!-- ROW 3: Route -->
                <TextBlock Grid.Row="3" x:Name="Route" Text="ROUTE: NOT DEFINED" Foreground="White" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" MaxHeight="60" Margin="0,0,0,5"/>

                <!-- ROW 4: Progress Bar -->
                <Border x:Name="ProgressBorder" Grid.Row="4" Background="#2A2C31" CornerRadius="0" Height="12" Margin="0,10,0,10" BorderBrush="#3A3C42" BorderThickness="1">
                    <ProgressBar x:Name="JobProgressBar" Minimum="0" Maximum="1" Value="0" Background="Transparent" Foreground="#52C14F" BorderThickness="0">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid>
                                    <Border x:Name="PART_Track" Background="Transparent"/>
                                    <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="0" HorizontalAlignment="Left"/>
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                </Border>

                <!-- ROW 5: Bottom Info Grid -->
                <Grid Grid.Row="5" x:Name="BottomInfoGrid" VerticalAlignment="Bottom" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Headers -->
                    <TextBlock x:Name="SpeedHeader" Grid.Row="0" Grid.Column="0" Text="SPEED" Foreground="#888888" FontSize="12" FontWeight="Bold"/>
                    <TextBlock x:Name="MaxHeader" Grid.Row="0" Grid.Column="1" Text="MAX" Foreground="#888888" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TypeHeader" Grid.Row="0" Grid.Column="2" Text="TYPE" Foreground="#888888" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>

                    <!-- SPEED Value -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock x:Name="SpeedValue" Text="0" Foreground="White" FontSize="52" FontWeight="Bold" Margin="0,0,0,-8" Width="31"/>
                        <TextBlock x:Name="SpeedUnit" Text="km/h" Foreground="White" FontSize="14" VerticalAlignment="Bottom" Margin="2,0,0,0"/>
                    </StackPanel>

                    <!-- MAX Value -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="80">
                        <TextBlock x:Name="MaxSpeedValue" Text="0" Foreground="#F39C12" FontSize="36" FontWeight="Bold" TextAlignment="Center" HorizontalAlignment="Stretch" Margin="0,0,0,-6"/>
                        <TextBlock x:Name="MaxUnit" Text="km/h" Foreground="White" FontSize="12" TextAlignment="Center" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    
                    <!-- TYPE Value -->
                    <TextBlock Grid.Row="1" Grid.Column="2" x:Name="DeliveryType" Text="N/A" Foreground="#52C14F" FontSize="26" FontWeight="Heavy" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="57,0,0,0"/>
                </Grid>
            </Grid>

            <!-- SETTINGS PANEL (Overlays the UI) -->
            <Border x:Name="SettingsPanel" Background="#F21A1C20" Visibility="Collapsed" Margin="-15" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SettingsTitle" Grid.Row="0" Text="SETTINGS" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,10,0,20">
                        <CheckBox x:Name="ChkShowDistance" Content="Show driving distance" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                        <CheckBox x:Name="ChkShowBottomInfo" Content="Show speed and delivery type" Checked="Settings_Changed" Unchecked="Settings_Changed" Margin="0,15,0,0"/>
                        <CheckBox x:Name="ChkShowRoute" Content="Show route" Checked="Settings_Changed" Unchecked="Settings_Changed" Margin="0,15,0,0"/>
                        <CheckBox x:Name="ChkShowProgress" Content="Show progress bar" Checked="Settings_Changed" Unchecked="Settings_Changed" Margin="0,15,0,0"/>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock x:Name="OpacityLabel" Text="Opacity" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Slider x:Name="OpacitySlider" Minimum="40" Maximum="100" Value="85" Width="160" ValueChanged="OpacitySlider_ValueChanged"/>
                            <TextBlock x:Name="OpacityValue" Text="85%" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock x:Name="LanguageLabel" Text="Language" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <ComboBox x:Name="LanguageSelector" Width="160" SelectionChanged="LanguageSelector_SelectionChanged">
                                <ComboBoxItem Content="English" Tag="en"/>
                                <ComboBoxItem Content="Українська" Tag="uk"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock x:Name="SpeedWarningLabel" Text="Speed warning" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="SpeedWarningBox" Width="120" Height="24" VerticalContentAlignment="Center" TextAlignment="Center" TextChanged="SpeedWarningBox_TextChanged"/>
                            <Grid Margin="6,0,0,0" Width="26" Height="24" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="12"/>
                                </Grid.RowDefinitions>
                                <Button x:Name="SpeedWarningUp" Grid.Row="0" Height="13" Click="SpeedWarningUp_Click" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock Text="▲" FontSize="10" LineHeight="12" LineStackingStrategy="BlockLineHeight" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                                <Button x:Name="SpeedWarningDown" Grid.Row="1" Height="13" Click="SpeedWarningDown_Click" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock Text="▼" FontSize="10" LineHeight="12" LineStackingStrategy="BlockLineHeight" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Update Section -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button x:Name="BtnCheckUpdate" Grid.Column="0" Content="🔄 Check for updates" Click="BtnCheckUpdate_Click"
                                    Background="#43A047" Foreground="White" BorderThickness="0"
                                    Height="32" HorizontalAlignment="Stretch" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="border" Property="Background" Value="#2A2C31"/>
                                                <Setter Property="Foreground" Value="#888888"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="BtnDonate" Grid.Column="2" Content="💛 Donate" Click="BtnDonate_Click"
                                    Background="#E8BA23" Foreground="Black" BorderThickness="0"
                                    Height="32" HorizontalAlignment="Stretch" Cursor="Hand" FontWeight="Bold">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                        
                        <TextBlock x:Name="UpdateStatusText" Text="" Foreground="#888888"
                                   FontSize="12" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" Margin="0,6,0,0"/>

                        <!-- Download Progress -->
                        <Grid x:Name="UpdateProgressPanel" Visibility="Collapsed" Margin="0,6,0,0">
                            <Border Background="#2A2C31" CornerRadius="3" Height="8">
                                <ProgressBar x:Name="UpdateProgressBar" Minimum="0" Maximum="100" Value="0"
                                             Background="Transparent" Foreground="#52C14F" BorderThickness="0">
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Grid>
                                                <Border x:Name="PART_Track" Background="Transparent"/>
                                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="3" HorizontalAlignment="Left"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Done Button -->
                    <Button x:Name="SettingsDoneButton" Grid.Row="3" Content="Done" Click="BtnCloseSettings_Click" Background="#33FFFFFF" Foreground="White" BorderThickness="0" Height="30" Width="100" HorizontalAlignment="Center" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#55FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Version Label -->
                    <TextBlock x:Name="VersionLabel" Grid.Row="4" Text="" Foreground="#555555"
                               FontSize="10" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>