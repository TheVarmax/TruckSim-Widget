<Window x:Class="ETSOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TruckSim Widget"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <Style x:Key="HeaderBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2D35"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3D45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtnStyle" TargetType="Button" BasedOn="{StaticResource HeaderBtnStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#252830"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#252830"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="BorderBrush" Value="#353840"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="GaugeCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#252830"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="BorderBrush" Value="#353840"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,3"/>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Width="340" Background="#1A1C20" CornerRadius="8" Padding="10" Margin="16">
        <Border.LayoutTransform>
            <ScaleTransform x:Name="UIScaleTransform" ScaleX="1.15" ScaleY="1.15"/>
        </Border.LayoutTransform>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="14" Opacity="0.5" Direction="270" ShadowDepth="3"/>
        </Border.Effect>

        <Grid x:Name="MainUI">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ROW 0: HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Ellipse x:Name="TbStatusDot" Width="7" Height="7" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TbStatus" Text="TB • ONLINE" Foreground="#4CAF50" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Click="BtnSettings_Click" Style="{StaticResource HeaderBtnStyle}" ToolTip="Settings" Margin="0,0,4,0">
                        <Path Data="M19.4 13c0-.33.05-.66.05-1s-.02-.67-.05-1l2.1-1.66c.2-.15.25-.42.13-.64l-2-3.46c-.12-.22-.4-.3-.6-.22l-2.5 1c-.5-.4-1.07-.73-1.68-.98l-.4-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.5.42l-.37 2.65c-.6.25-1.17.58-1.68.98l-2.5-1c-.22-.08-.48 0-.6.22l-2 3.46c-.13.22-.07.49.12.64L4.57 11c-.03.33-.07.67-.07 1s.04.67.07 1l-2.1 1.66c-.2.15-.25.42-.12.64l2 3.46c.12.22.38.3.6.22l2.5-1c.5.4 1.07.73 1.68.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.5-.42l.37-2.65c.6-.25 1.17-.58 1.68-.98l2.5 1c.22.08.48 0 .6-.22l2-3.46c.12-.22.07-.49-.12-.64L19.4 13zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" Fill="#B0B0B0" Stretch="Uniform" Width="12" Height="12"/>
                    </Button>
                    <Button x:Name="BtnTopmost" Click="BtnTopmost_Click" Style="{StaticResource HeaderBtnStyle}" ToolTip="Pin" Margin="0,0,4,0">
                        <Path x:Name="PinIcon" Data="M16,12V4H17V2H7V4H8V12L6,14V16H11V22H13V16H18V14L16,12Z" Fill="#B0B0B0" Stretch="Uniform" Width="10" Height="10"/>
                    </Button>
                    <Button Click="BtnMinimize_Click" Style="{StaticResource HeaderBtnStyle}" Margin="0,0,4,0">
                        <Path Data="M0,0 L12,0" Stroke="#B0B0B0" StrokeThickness="2" Stretch="Uniform" Width="10" VerticalAlignment="Center"/>
                    </Button>
                    <Button Click="BtnClose_Click" Style="{StaticResource CloseBtnStyle}">
                        <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="#B0B0B0" StrokeThickness="2" Stretch="Uniform" Width="8" Height="8" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ROW 1 & 2: TOP INFO CARDS -->
            <Grid Grid.Row="1" Margin="0,0,0,6" x:Name="CardsGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- GAME Card -->
                <Border x:Name="GameCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource InfoCardStyle}" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#1E2028" CornerRadius="16" Width="32" Height="32">
                            <Path Data="M15 7.5V2H9v5.5l3 3 3-3zM7.5 9H2v6h5.5l3-3-3-3zM9 16.5V22h6v-5.5l-3-3-3 3zM16.5 9l-3 3 3 3H22V9h-5.5z" Fill="#7AC5CD" Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="GameLabel" Text="GAME" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="GameStatus" Text="ACTIVE" Foreground="#4CAF50" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SIM Card -->
                <Border x:Name="SimCard" Grid.Row="0" Grid.Column="2" Style="{StaticResource InfoCardStyle}" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#1E2028" CornerRadius="16" Width="32" Height="32">
                            <Path Data="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9 1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" Fill="#90CAF9" Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="SimLabel" Text="SIM" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="SimValue" Text="N/A" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- STATUS Card -->
                <Border x:Name="StatusCard" Grid.Row="1" Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#1E2028" CornerRadius="16" Width="32" Height="32">
                            <Path Data="M12 6v3l4-4-4-4v3c-4.42 0-8 3.58-8 8 0 1.57.46 3.03 1.24 4.26L6.7 14.8c-.45-.83-.7-1.79-.7-2.8 0-3.31 2.69-6 6-6zm6.76 1.74L17.3 9.2c.44.84.7 1.79.7 2.8 0 3.31-2.69 6-6 6v-3l-4 4 4 4v-3c4.42 0 8-3.58 8-8 0-1.57-.46-3.03-1.24-4.26z" Fill="#7AC5CD" Stretch="Uniform" Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusLabel" Text="STATUS" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="StatusValue" Text="Wait for game..." Foreground="#A0A0A0" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,-8,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- DISTANCE Card -->
                <Border x:Name="DistanceCard" Grid.Row="1" Grid.Column="2" Style="{StaticResource InfoCardStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#1E2028" CornerRadius="16" Width="32" Height="32">
                            <Path Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" Fill="#52C14F" Stretch="Uniform" Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="DistanceLabel" Text="DISTANCE" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            <TextBlock x:Name="DistanceInfo" Text="0 / 0 km" Foreground="#52C14F" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ROW 3: ROUTE CARD -->
            <Border x:Name="RouteCard" Grid.Row="3" Style="{StaticResource InfoCardStyle}" Margin="0,0,0,6">
                <Grid>
                    <!-- SINGLE LINE LAYOUT -->
                    <StackPanel x:Name="RouteSingleLineGrid" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1E2028" CornerRadius="16" Width="32" Height="32">
                            <Path Data="M21 3L3 10.53v.98l6.84 2.65L12.48 21h.98L21 3z" Fill="#B0B0B0" Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="RouteLabel" Text="ROUTE" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        
                        <Border Width="2" Background="#353840" CornerRadius="1" Margin="10,2,10,2"/>
                        
                        <TextBlock x:Name="Route" Text="NOT DEFINED" Foreground="White" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" MaxWidth="220" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- MULTI LINE LAYOUT -->
                    <StackPanel x:Name="RouteMultiLineGrid" Visibility="Collapsed" VerticalAlignment="Center" Margin="0,2,0,2">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Background="#1E2028" CornerRadius="12" Width="24" Height="24">
                                <Path Data="M21 3L3 10.53v.98l6.84 2.65L12.48 21h.98L21 3z" Fill="#B0B0B0" Stretch="Uniform" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="RouteLabelMulti" Text="ROUTE" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </StackPanel>
                        
                        <Border Height="2" Background="#353840" CornerRadius="1" Margin="10,6,10,6"/>
                        
                        <TextBlock x:Name="RouteMulti" Text="NOT DEFINED" Foreground="White" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ROW 4: BOTTOM GAUGES -->
            <Grid Grid.Row="4" x:Name="BottomInfoGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SPEED Gauge -->
                <Border Grid.Column="0" Style="{StaticResource GaugeCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="SpeedHeader" Grid.Row="0" Text="SPEED" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>



                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock x:Name="SpeedValue" Text="0" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock x:Name="SpeedUnit" Grid.Row="2" Text="km/h" Foreground="#888888" FontSize="9" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                    </Grid>
                </Border>

                <!-- MAX Gauge -->
                <Border Grid.Column="2" Style="{StaticResource GaugeCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="MaxHeader" Grid.Row="0" Text="MAX" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>



                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock x:Name="MaxSpeedValue" Text="0" Foreground="#F39C12" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock x:Name="MaxUnit" Grid.Row="2" Text="km/h" Foreground="#888888" FontSize="9" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                    </Grid>
                </Border>

                <!-- TYPE -->
                <Border Grid.Column="4" Style="{StaticResource GaugeCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="TypeHeader" Grid.Row="0" Text="TYPE" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>

                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock x:Name="DeliveryType" Text="N/A" Foreground="Gray" FontSize="20" FontWeight="Heavy" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Empty placeholder to match exact Row 2 layout of Speed/Max cards for perfect vertical alignment -->
                        <TextBlock Grid.Row="2" Text=" " FontSize="9" Margin="0,-2,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>