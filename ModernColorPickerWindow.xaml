<Window x:Class="ETSOverlay.ModernColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Color Picker" Width="380" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" Topmost="True" ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="255"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="12" Padding="20" Margin="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="{DynamicResource ShadowOpacity}" Direction="270" ShadowDepth="4"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="TitleBlock" Text="Choose Color" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource MainTextBrush}"/>

            <WrapPanel x:Name="SwatchesPanel" Margin="0,0,0,15" HorizontalAlignment="Center"/>

            <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,5,0,15"/>

            <!-- SV Canvas & Hue Slider -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="15" />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>

                <!-- Color Canvas -->
                <Grid x:Name="ColorCanvas" Height="160" Grid.Column="0" Background="Transparent" MouseLeftButtonDown="Canvas_MouseDown" MouseMove="Canvas_MouseMove" MouseLeftButtonUp="Canvas_MouseUp" MouseLeave="Canvas_MouseLeave" Cursor="Cross">
                    <Border x:Name="ColorCanvasBackground" Background="Red" CornerRadius="4" />
                    <Border CornerRadius="4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="White" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border CornerRadius="4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="Black" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Canvas ClipToBounds="True">
                        <Ellipse x:Name="ColorThumb" Width="14" Height="14" Stroke="White" StrokeThickness="2" IsHitTestVisible="False">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                </Grid>

                <!-- Hue Slider -->
                <Grid Grid.Column="2" Height="160">
                    <Border CornerRadius="4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                <GradientStop Color="#FF0000" Offset="0"/>
                                <GradientStop Color="#FFFF00" Offset="0.167"/>
                                <GradientStop Color="#00FF00" Offset="0.333"/>
                                <GradientStop Color="#00FFFF" Offset="0.5"/>
                                <GradientStop Color="#0000FF" Offset="0.667"/>
                                <GradientStop Color="#FF00FF" Offset="0.833"/>
                                <GradientStop Color="#FF0000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Slider x:Name="HueSlider" Orientation="Vertical" Minimum="0" Maximum="360" Value="0" ValueChanged="HueSlider_ValueChanged" Opacity="0" />
                    <Canvas IsHitTestVisible="False" ClipToBounds="False">
                        <Border x:Name="HueThumb" Width="24" Height="6" BorderBrush="White" BorderThickness="2" CornerRadius="2" Margin="-2,-3,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>
                    </Canvas>
                </Grid>
            </Grid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="PreviewBorder" Width="40" Height="40" CornerRadius="6" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Margin="0,0,10,0"/>
                    <TextBlock x:Name="PreviewHex" Text="#000000" VerticalAlignment="Center" FontSize="16" FontFamily="Consolas" Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnCancel" Grid.Column="0" Content="Cancel" Click="BtnCancel_Click" Background="{DynamicResource InputBackgroundBrush}" Style="{StaticResource DialogButton}"/>
                <Button x:Name="BtnSave" Grid.Column="2" Content="Select" Click="BtnSave_Click" Background="#43A047" Style="{StaticResource DialogButton}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
